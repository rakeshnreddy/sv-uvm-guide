// Component: DMA Controller resource
component dma_controller {
    // Memory regions available to the DMA
    resource mem_region {
        rand bit [31:0] base_addr;
        rand bit [31:0] size;

        constraint valid_alignment {
            base_addr % 4 == 0;   // Word-aligned
            size > 0;
        }
    }

    // Pool of memory regions
    pool mem_region src_pool;
    pool mem_region dst_pool;

    // Bind pools to actions
    bind src_pool *;
    bind dst_pool *;
}

